# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (for server-side operations only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database URL (optional, for direct database access)
DATABASE_URL=postgresql://user:password@host:port/database

# Auth Redirect URLs
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_PROD_SUPABASE_REDIRECT_URL=https://your-vercel-domain.vercel.app/auth/callback

# Biometric API Configuration (optional)
BIOMETRIC_API_KEY=your_api_key_here
BIOMETRIC_DEVICE_SECRET=your_device_secret_here
